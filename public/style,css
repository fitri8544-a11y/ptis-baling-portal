.chatbot-icon {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 8px 20px rgba(0,0,0,0.25);
  border: 3px solid white;
  animation: pulse 2.5s infinite;
}

.chatbot-icon img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.chatbot-icon {
  box-shadow: 
    0 8px 20px rgba(0,0,0,0.25),
    0 0 15px rgba(255,255,255,0.6);
}